{
    "name": "romrack",
    "version": "0.2.1",
    "repository": "https://github.com/qwell/romrack",
    "author": "Jason Parker",
    "license": "GPL-3.0-or-later",
    "bugs": {
        "url": "https://github.com/qwell/romrack/issues",
        "email": "north@ntbox.com"
    },
    "funding": {
        "type": "patreon",
        "url": "https://www.patreon.com/northantara"
    },
    "keywords": [
        "wiiu",
        "wii",
        "3ds",
        "roms"
    ],
    "main": "dist/index.js",
    "type": "module",
    "typings": "dist/index.d.ts",
    "files": [
        "dist/"
    ],
    "engines": {
        "node": ">=24.0.0"
    },
    "os": [
        "linux",
        "win32",
        "darwin"
    ],
    "packageManager": "yarn@4.17.0",
    "scripts": {
        "lint": "eslint --cache --cache-strategy metadata --cache-location ./.cache/eslint .",
        "format": "prettier --write --cache --cache-strategy metadata --cache-location ./.cache/prettier .",
        "hygiene": "yarn format && yarn lint",
        "clean": "rimraf dist/ release/ .cache/",
        "build": "tsx scripts/build.ts",
        "start": "tsx scripts/start.ts",
        "start:raw": "yarn build && APP_ROOT=\"$PWD/dist\" node dist/server/index.js",
        "test": "vitest run",
        "release": "yarn clean && yarn build && tsx scripts/release.ts all",
        "release:stage": "yarn clean && yarn build && tsx scripts/release.ts stage",
        "release:zip": "tsx scripts/release.ts zip",
        "generate:titles": "tsx scripts/generate-titles.ts && yarn hygiene"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@tsconfig/node24": "^24.0.4",
        "@types/adm-zip": "^0.5.8",
        "@types/eslint": "^9.6.1",
        "@types/express": "^5.0.6",
        "@types/node": "^25.9.1",
        "@types/prettier": "^3.0.0",
        "@types/ws": "^8.18.1",
        "@typescript-eslint/eslint-plugin": "^8.60.1",
        "@typescript-eslint/parser": "^8.60.1",
        "@yarnpkg/sdks": "^3.3.0",
        "adm-zip": "^0.5.17",
        "cheerio": "^1.2.0",
        "eslint": "^10.4.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "globals": "^17.6.0",
        "prettier": "^3.8.3",
        "rimraf": "^6.1.3",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.1",
        "typescript-eslint-language-service": "^5.0.5",
        "vite": "^7.3.5",
        "vitest": "^4.1.8"
    },
    "dependencies": {
        "@types/node-forge": "^1.3.14",
        "csv-parse": "^6.2.1",
        "express": "^5.2.1",
        "fast-xml-parser": "^5.8.0",
        "node-forge": "^1.4.0",
        "open": "^11.0.0",
        "ws": "^8.21.0"
    }
}
